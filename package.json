{
  "name": "itmo-handlebars",
  "version": "1.0.0",
  "description": "Node.js CLI for rendering Handlebars templates with JSON context.",
  "main": "src/renderer.js",
  "bin": {
    "itmo-handlebars": "bin/hbs-runner.js"
  },
  "scripts": {
    "test": "vitest run",
    "render:example": "node bin/hbs-runner.js --template templates/example.hbs --context data/context.json",
    "sandbox": "node src/server.js"
  },
  "keywords": [
    "handlebars",
    "cli",
    "templates",
    "itmo"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "handlebars": "^4.7.9",
    "nunjucks": "^3.2.4",
    "pug": "^3.0.4"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
